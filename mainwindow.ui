   <property name="styleSheet">
    <string notr="true">*{
  color: #000;
  border: none;
  font-family: &quot;Poppins&quot;;
}
#centralwidget{
background: none;
border:2px solid #fff;
}
#leftMenu{
   background: rgb(1, 141, 127);
}
#label_Dashboard{
  color:rgb(1, 141, 127);
}
QLineEdit{
background: transparent;
  color: rgb(14,189,175);
}
#searchFrame_2,
#searchFrame{
 border-radius: 10px;
 border: 2px solid rgb(14,189,175);
}
#appHeader{
  color: rgb(14,189,175);
}
#card1, #card2, #card3, #card4{
 background-color: #fefeff;
 border-radius: 10px;
}
#pushButton,#pushButton_2,#pushButton_chercher,#pushButton_modifier{
background-color: rgb(14,189,175);
color: #fff;
 border-radius: 10px;
}
#widget_4,#widget_5,#profilecontent{
 background-color: #fefeff;
 border-radius: 10px;
}
#header_top
{
  background: rgb(1, 141, 127);
}
#title{
color: #fff;
}
#headerFrame{
background-color: #fefeff;
}
#pushButton_client,
#pushButton_employe, #pushButton_setting,#pushButton_service,#pushButton_station,#pushButton_help,#pushButton_about,#pushButton_chargeur{
background-color: #fefeff;  
color: #000;
padding: 10px 5px;
text-align: left;
border-top-left-radius: 20px;

}

#pushButton_home:hover,
#pushButton_client:hover,
#pushButton_employe:hover, #pushButton_setting:hover,#pushButton_service:hover,#pushButton_station:hover,#pushButton_help:hover,#pushButton_about:hover,#pushButton_chargeur:hover{

color:rgb(8, 103, 94);
padding: 10px 5px;
text-align: left;
border-top-left-radius: 20px;
}

QPushButton{
padding: 10px 5px;
text-align: left;
}
#groupBox{
 border: 2px dotted rgb(14,189,175);
 border-radius: 10px;
}
#pushButton_AJOUTER{
 border-radius: 10px;
}
#pushButton_login:hover{
background: rgb(86,86,86);

}
#pushButton_load{
 background:   #fefeff;
border-top-left-radius: 20px;
border-bottom-right-radius: 20px;
}
#SingleView{
border : 2px solid rgb(1, 141, 127);
}
#text_id, #text_nom, #text_prenom,#text_age{
border : 1px solid rgb(1, 141, 127);
}
#lineEdit_chercher,#pushButton_capture_st{
 border-radius: 10px;
 border: 2px solid rgb(1, 141, 127);
}
#text_id,#text_prenom,#comboBox_R,#lineEdit_chercherE,#text_nom,#text_age,#text_mail,#text_mdp{
color: #868686;
}
#pushButton_profile, #pushButton_logout
{
 border-radius: 10px;
 border: 2px solid  rgb(1, 141, 127);
background:  rgb(1, 141, 127);
}
#pushButton_profile:hover, #pushButton_logout:hover{
background:  rgb(1, 141, 127);
}
#pushButton_capture_st:hover{
color:  rgb(1, 141, 127);
}</string>
