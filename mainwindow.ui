                                      <property name="whatsThis">
                                       <string>#frame_4{
    position: relative;
    width:70vw;
    height: 80vh;
    background: #fff;
    border-radius: 15px;
    box-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.3), 0 6px 20px 0 rgba(0, 0, 0, 0.3);
    overflow: hidden;
}
/* non intg */
#frame_4::before{
    content: &quot;&quot;;
    position: absolute;
    top: 0;
    left: -50%;
    width: 100%;
    height: 100%;
    background: linear-gradient(-45deg,rgb(1, 141, 127),rgb(8, 103, 94));
     z-index: 6;
     transform: translateX(100%);
     transition: 1s ease-in-out;
}</string>
                                      </property>
