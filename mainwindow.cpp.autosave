 QString cheminAbsolu;
QString MainWindow::on_pb_image_clicked()
{

    QString filename = QFileDialog::getOpenFileName(this, tr("Choose Image"),"",tr("Images (*.png *.jpg *.jpeg *.bmp *.gif)"));
    if (!filename.isEmpty())
    {
        QImage image(filename);
        if (image.isNull())
        {
            QMessageBox::critical(nullptr, tr("Error"), tr("Failed to load image."));
            return QString();
        }

        QPixmap pixmap = QPixmap::fromImage(image);
        if (pixmap.isNull())
        {
            QMessageBox::critical(nullptr, tr("Error"), tr("Failed to convert image to pixmap."));
            return QString();
        }

        ui->tb_image->setPixmap(pixmap);
        ui->label_image->setText(filename);

        QMessageBox::information(nullptr, tr("Image Importée"), tr("Imporation avec succès."));
        QFileInfo fileinfo(filename);
        cheminAbsolu = fileinfo.filePath();
    }

    return cheminAbsolu;
}

void MainWindow::on_pb_ajouter_clicked()
{
    // Vérifier si tous les champs sont remplis
    if (ui->le_code->text().isEmpty() || ui->le_prix->text().isEmpty() || ui->le_type->text().isEmpty() || ui->le_cin->text().isEmpty() || cheminAbsolu.isEmpty()) {
        QMessageBox::warning(this, tr("Champs manquants"), tr("Veuillez remplir tous les champs avant d'ajouter une offre et importer une image."));
        return;
    }

    // Convertir les valeurs des champs en types appropriés
    int code = ui->le_code->text().toInt();
    int prix = ui->le_prix->text().toInt();
    QString type = ui->le_type->text();
    int cin_e = ui->le_cin->text().toInt();
    QString photos = cheminAbsolu;

    // Vérifier l'existence de l'employé
    if (!Etmp.rechercherEmploye(cin_e)) {
        QMessageBox::critical(nullptr, QObject::tr("Ajout d'un offre"),
            QObject::tr("L'employé avec le CIN %1 n'existe pas!\n"
                        "Veuillez vérifier l'ID de l'employé et réessayer.").arg(cin_e),
            QMessageBox::Cancel);
        return;
    }

    // Ajouter l'offre
    offre o(code, prix, type, cin_e, photos);
    bool test = o.ajouter();
    if (test) {
        QMessageBox::information(nullptr, QObject::tr("Ajout d'un offre"),
            QObject::tr("Ajout effectué\nClick cancel to exit."), QMessageBox::Cancel);
        ui->tab_offre->setModel(o.afficher()); // Rafraîchir la vue des offres
        ui->le_code->clear();
        ui->le_prix->clear();
        ui->le_type->clear();
        ui->le_cin->clear();
        ui->tb_image->clear();
        ui->label_image->clear();
        cheminAbsolu.clear();
    }
    else {
        QMessageBox::critical(nullptr, QObject::tr("Ajout d'un offre"),
            QObject::tr("Ajout non effectué\nClick cancel to exit."), QMessageBox::Cancel);
    }
}

