void MainWindow::on_tableView_activated(const QModelIndex &index)
{
    QString val=ui->tableView->model()->data(index).toString();
    //int v = ui->tableView->model()->data(index).toInt();
     //ui->comboBox_R->setCurrentText("");
    QSqlQuery query;


    query.prepare( "select * from employes where CINE ='"+val+"'");

    if(query.exec())
    {

        while(query.next())
        {
              ui->text_id->setText(query.value(0).toString());
              ui->text_nom->setText(query.value(1).toString());
              ui->text_prenom->setText(query.value(2).toString());
              ui->text_mail->setText(query.value(3).toString());
              ui->text_age->setText(query.value(4).toString());
              ui->comboBox_R->setCurrentText(query.value(5).toString());
              ui->text_mdp->setText(query.value(6).toString());

        }
         QString val=ui->tableView->model()->data(index).toString();
    }



}

void MainWindow::on_pushButton_supprimer_clicked()
{
    // Vérifier si les champs de suppression sont vides
    if(ui->text_id->text().isEmpty() || ui->text_nom->text().isEmpty() || ui->text_prenom->text().isEmpty() || ui->text_mail->text().isEmpty() || ui->text_age->text().isEmpty() || ui->comboBox_R->currentText().isEmpty() || ui->text_mdp->text().isEmpty()) {
        QMessageBox::warning(this, "Champs vides", "Veuillez remplir tous les champs de suppression.");
        return;
    }

    int id = ui->text_id->text().toInt();

    QMessageBox::StandardButton confirmation = QMessageBox::question(this, "Confirmation de suppression", "Voulez-vous vraiment supprimer cet élément ?");

    if (confirmation == QMessageBox::Yes) {
        bool test = Etmp.supprimer(id);
        if(test)
        {
            ui->tableView->setModel(Etmp.afficher());
            ui->text_id->setText("");
            ui->text_nom->setText("");
            ui->text_prenom->setText("");
            ui->text_mail->setText("");
            ui->text_age->setText("");
            ui->comboBox_R->setCurrentText("");
            ui->text_mdp->setText("");
              ui->lineEdit_chercherE->setText("");
            QMessageBox::information(nullptr, QObject::tr("succès !"),
                        QObject::tr("supprimé avec succès.\n"
                                    "Click Ok to exit."), QMessageBox::Ok);

        }
        else
            QMessageBox::critical(nullptr, QObject::tr("echec !"),
                        QObject::tr("la suppression a échoué.\n"
                                    "Click Cancel to exit."), QMessageBox::Cancel);
    }
}

void MainWindow::on_pushButton_modifier_clicked()
{
    int cin = ui->text_id->text().toInt();
    QString nom = ui->text_nom->text();
    QString prenom = ui->text_prenom->text();
    QString mail = ui->text_mail->text();
    int age = ui->text_age->text().toInt();
    QString role = ui->comboBox_R->currentText();
    QString mdp = ui->text_mdp->text();

     // Vérification que tous les champs sont remplis
     if (cin == 0 || nom.isEmpty() || prenom.isEmpty() || mail.isEmpty() || age == 0 || mdp.isEmpty()) {
         QMessageBox::critical(nullptr, QObject::tr("Erreur"),
             QObject::tr("Tous les champs sont obligatoires.\n"
                         "Veuillez remplir tous les champs."), QMessageBox::Cancel);
         return;
     }
     // Vérification que le nom contient plus de 3 caractères et ne contient pas de chiffres
     if (nom.length() < 3 || nom.contains(QRegExp("[0-9]"))) {
         QMessageBox::critical(nullptr, QObject::tr("Erreur"),
             QObject::tr("Veuillez saisir un nom valide !"), QMessageBox::Cancel);
         return;
     }
     // Vérification de la validité du mail
     //QRegularExpression regex("\\b[a-z0-9._%+-]+@esprit\\.tn\\b");
 QRegularExpression regex("^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");
     if (!regex.match(mail).hasMatch()) {
         QMessageBox::critical(nullptr, QObject::tr("Erreur"),
             QObject::tr("Veuillez saisir une adresse mail valide !"), QMessageBox::Cancel);
         return;
     }
     // Vérification que l'âge est supérieur ou égal à 18 ans
     if (age < 18) {
         QMessageBox::critical(nullptr, QObject::tr("Erreur"),
             QObject::tr("L'âge doit être supérieur ou égal à 18 ans."), QMessageBox::Cancel);
         return;
     }
     // Vérification que le mot de passe contient au moins 8 caractères, une lettre minuscule, une lettre majuscule, un chiffre et un caractère spécial
     QRegularExpression passwordRegex("^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$");
     if (!passwordRegex.match(mdp).hasMatch()) {
           ui->lineEdit_MESSAGE->setText("");
         QMessageBox::critical(nullptr, QObject::tr("Erreur"),
           QObject::tr("Le mot de passe doit contenir au moins 8 caractères, une lettre minuscule, une lettre majuscule, un chiffre et un caractère spécial."), QMessageBox::Ok);
     return;
     }

    Employe E(cin, nom, prenom, mail, age, role, mdp);
    bool test = E.modifier();

    if (test) {
        ui->tableView->setModel(Etmp.afficher());
        QMessageBox::information(nullptr, QObject::tr("succès !"),
                    QObject::tr("modifié avec succès.\n"
                                "Click Ok to exit."), QMessageBox::Ok);

    }

    else {
        QMessageBox::critical(nullptr, QObject::tr("echec !"),
                    QObject::tr("la modification a échoué.\n"
                                "Click Cancel to exit."), QMessageBox::Cancel);
    }

}

