void MainWindow::makePlot_second()
{


       //
       // create empty bar chart objects:
        QCPBars *regen = new QCPBars(ui->customPlot_second->xAxis, ui->customPlot_second->yAxis);
        QCPBars *nuclear = new QCPBars(ui->customPlot_second->xAxis, ui->customPlot_second->yAxis);
        QCPBars *fossil = new QCPBars(ui->customPlot_second->xAxis, ui->customPlot_second->yAxis);
        regen->setAntialiased(false); // gives more crisp, pixel aligned bar borders
        nuclear->setAntialiased(false);
        fossil->setAntialiased(false);
        regen->setWidth(0.8);
        nuclear->setWidth(0.8);
        fossil->setWidth(0.8);
        // set names and colors:
        fossil->setName("Fossil fuels");
        fossil->setPen(QPen(QColor(111, 9, 176).lighter(170)));
        fossil->setBrush(QColor(111, 9, 176));
        nuclear->setName("Nuclear");
        nuclear->setPen(QPen(QColor(250, 170, 20).lighter(150)));
        nuclear->setBrush(QColor(250, 170, 20));
        regen->setName("Regenerative");
        regen->setPen(QPen(QColor(0, 168, 140).lighter(130)));
        regen->setBrush(QColor(0, 168, 140));
        // stack bars on top of each other:
        nuclear->moveAbove(fossil);
        regen->moveAbove(nuclear);

       // create empty bar chart objects:
       QCPBars *employe = new QCPBars(ui->customPlot_second->xAxis, ui->customPlot_second->yAxis);
       ui->customPlot_second->addPlottable(employe);
       // set names and colors:
       QPen pen;
       pen.setWidthF(0.5);
       employe->setName("Nombre d'employés/Rôle");
       pen.setColor(QColor(255, 131, 0));
       employe->setPen(pen);
       employe->setBrush(QColor(255, 131, 0, 50));

       // prepare x axis with country labels:
       QVector<double> ticks;
       QVector<QString> labels = Etmp.getListNom();
          for (int i=0;i<labels.size();i++){
              ticks<< (i+0.5);
          }

       ui->customPlot_second->xAxis->setAutoTicks(false);
       ui->customPlot_second->xAxis->setAutoTickLabels(false);
       ui->customPlot_second->xAxis->setTickVector(ticks);
       ui->customPlot_second->xAxis->setTickVectorLabels(labels);
       ui->customPlot_second->xAxis->setTickLabelRotation(60);
       ui->customPlot_second->xAxis->setSubTickCount(0);
       ui->customPlot_second->xAxis->setTickLength(0, 4);
       ui->customPlot_second->xAxis->grid()->setVisible(true);
       ui->customPlot_second->xAxis->setRange(0, ticks.size());

       // prepare y axis:
       ui->customPlot_second->yAxis->setRange(0, 50.1);
       ui->customPlot_second->yAxis->setPadding(5); // a bit more space to the left border
       ui->customPlot_second->yAxis->setLabel("Nombre des employés");
       ui->customPlot_second->yAxis->grid()->setSubGridVisible(true);
       QPen gridPen;
       gridPen.setColor(QColor(0, 0, 0, 25));
       ui->customPlot_second->yAxis->grid()->setPen(gridPen);
       gridPen.setStyle(Qt::DotLine);
       ui->customPlot_second->yAxis->grid()->setSubGridPen(gridPen);

       // Add data:
       QSqlQuery q("SELECT age  FROM employes");


       QVector<double> employeData,employeData1;
       int count = 0; // initialise le compteur à 0
       while (q.next()) {
           count++; // incrémenter le compteur
           employeData.append(q.value(0).toDouble()); // ajouter la donnée de l'employé aux données
            //employeData1.append(q.value(1).toDouble());
       }

       //QVector<double> ticks;


      // QCPBars *employe = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);
       employe->setData(ticks, employeData);
      // employe->setData(ticks, employeData1);

       // setup legend:
       ui->customPlot_second->legend->setVisible(true);
       ui->customPlot_second->axisRect()->insetLayout()->setInsetAlignment(0, Qt::AlignTop|Qt::AlignHCenter);
       ui->customPlot_second->legend->setBrush(QColor(255, 255, 255, 200));

       QPen legendPen;
       legendPen.setColor(QColor(130, 130, 130, 200));
       ui->customPlot_second->legend->setBorderPen(legendPen);

       QFont legendFont = font();
       legendFont.setPointSize(10);
       ui->customPlot_second->legend->setFont(legendFont);
       ui->customPlot_second->setInteractions(QCP::iRangeDrag | QCP::iRangeZoom);
}
void MainWindow::chartPie(){
    // Récupération des données
    int nbA = 0;
    int nbB = 0;
    int nbC = 0;

    QSqlQuery A("SELECT * FROM services ");
    while (A.next()) {
        nbA++;
    }

    QSqlQuery B("SELECT * FROM employes ");
    while (B.next()) {
        nbB++;
    }

    QSqlQuery C("SELECT * FROM services where type like 'equipement'");
    while (C.next()) {
        nbC++;
    }

    // Configuration du graphique
    ui->customPlot_ChartPie->addGraph();
    ui->customPlot_ChartPie->graph(0)->setPen(QPen(Qt::black));
    ui->customPlot_ChartPie->graph(0)->setBrush(QBrush(QColor(255, 0, 0, 50)));
    ui->customPlot_ChartPie->graph(0)->setData(QVector<double>() << nbA << nbB << nbC, QVector<double>() << 0 << 1 << 2);
    ui->customPlot_ChartPie->graph(0)->setLineStyle(QCPGraph::lsLine);
    ui->customPlot_ChartPie->graph(0)->setScatterStyle(QCPScatterStyle(QCPScatterStyle::ssCircle, 5));
    ui->customPlot_ChartPie->graph(0)->setName("Répartition des services");

    // Configuration de l'axe des x

    ui->customPlot_ChartPie->xAxis->setTickLength(0, 4);
    ui->customPlot_ChartPie->xAxis->setRange(-0.5, 2.5);

    // Configuration de l'axe des y
    ui->customPlot_ChartPie->yAxis->setRange(0, qMax(nbA, qMax(nbB, nbC))+1);

    // Configuration de la légende
    ui->customPlot_ChartPie->legend->setVisible(true);
    ui->customPlot_ChartPie->legend->setFont(QFont("Arial", 9));
    ui->customPlot_ChartPie->legend->setRowSpacing(-3);

    // Rafraîchissement du graphique
    ui->customPlot_ChartPie->replot();


}
void MainWindow::makePlot()
{


    // change all text color to white
    QPalette plotPalette = ui->customPlot->palette();
    plotPalette.setColor(QPalette::WindowText, Qt::white);
    plotPalette.setColor(QPalette::Text, Qt::white);
    ui->customPlot->setPalette(plotPalette);


    // create empty bar chart objects:
    QCPBars *admin = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);
    QCPBars *agent_de_securite = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);
    QCPBars *agent_de_service = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);
    QCPBars *agent_entretien = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);
      QCPBars *retraite = new QCPBars(ui->customPlot->xAxis, ui->customPlot->yAxis);

    // add the bars to the plot and set their names and colors:
    ui->customPlot->addPlottable(admin);
    ui->customPlot->addPlottable(agent_de_securite);
    ui->customPlot->addPlottable(agent_de_service);
    ui->customPlot->addPlottable(agent_entretien);
    ui->customPlot->addPlottable(retraite);


    QPen pen;
    pen.setWidthF(1.2);

    admin->setName("Admin");
    pen.setColor(QColor(150, 222, 0));
    admin->setPen(pen);
    admin->setBrush(QColor(150, 222, 0, 70));

    agent_de_securite->setName("Agent de sécurité");
    pen.setColor(QColor(1, 92, 191));
    agent_de_securite->setPen(pen);
    agent_de_securite->setBrush(QColor(1, 92, 191, 50));

    agent_de_service->setName("Agent de services");
    pen.setColor(QColor(255, 131, 0));
    agent_de_service->setPen(pen);
    agent_de_service->setBrush(QColor(255, 131, 0, 50));

    agent_entretien->setName("Agent d'entretien");
    pen.setColor(QColor(255, 0, 0));
    agent_entretien->setPen(pen);
    agent_entretien->setBrush(QColor(255, 0, 0, 50));

    retraite->setName("Retraite");
    pen.setColor(QColor(255, 0, 0));
    retraite->setPen(pen);
    retraite->setBrush(QColor(250, 0, 250, 50));

    // stack bars on top of each other:
    agent_de_service->moveAbove(retraite);
    agent_de_securite->moveAbove(retraite);
    admin->moveAbove(retraite);
    //retraite->moveAbove(admin);


    // prepare x axis with country labels:
    QVector<double> ticks;
    QVector<QString> labels = Etmp.getListNom();

    for (int i = 0; i < labels.size(); i++){
        ticks << (i + 1);
    }

    ui->customPlot->xAxis->setAutoTicks(false);
    ui->customPlot->xAxis->setAutoTickLabels(false);
    ui->customPlot->xAxis->setTickVector(ticks);
    ui->customPlot->xAxis->setTickVectorLabels(labels);
    ui->customPlot->xAxis->setTickLabelRotation(60);
    ui->customPlot->xAxis->setSubTickCount(0);
    ui->customPlot->xAxis->setTickLength(0, 4);
    ui->customPlot->xAxis->grid()->setVisible(true);
    ui->customPlot->xAxis->setRange(0, labels.size() + 1);

    // prepare y axis:



// prepare y axis:
ui->customPlot->yAxis->setRange(0, 25.1);
ui->customPlot->yAxis->setPadding(5); // a bit more space to the left border
ui->customPlot->yAxis->setLabel("Rôle/ Employé (2023)");
ui->customPlot->yAxis->grid()->setSubGridVisible(true);
QPen gridPen;
gridPen.setStyle(Qt::SolidLine);
gridPen.setColor(QColor(0, 0, 0, 25));
ui->customPlot->yAxis->grid()->setPen(gridPen);
gridPen.setStyle(Qt::DotLine);
ui->customPlot->yAxis->grid()->setSubGridPen(gridPen);

// Add data:
QVector<double> Admin_Data, Securite_Data, Service_Data,Entretien_Data,Retraite_Data;

//Implémenter une boucle !
for (int i=0;i<labels.size();i++){


    Admin_Data << Etmp.getNombreEmployeParRole(labels[i],"Admin");
    Securite_Data << Etmp.getNombreEmployeParRole(labels[i],"Agent de securite");
    Service_Data <<Etmp.getNombreEmployeParRole(labels[i],"Agent de Service");
    Entretien_Data <<Etmp.getNombreEmployeParRole(labels[i],"Agent d'entretien");
    Retraite_Data <<Etmp.getNombreEmployeRetraite(labels[i],50,60);
}




admin->setData(ticks, Admin_Data);
agent_de_securite->setData(ticks, Securite_Data);
agent_de_service->setData(ticks, Service_Data);
agent_entretien->setData(ticks, Entretien_Data);
retraite->setData(ticks, Retraite_Data);




// setup legend:
ui->customPlot->legend->setVisible(true);
ui->customPlot->axisRect()->insetLayout()->setInsetAlignment(0, Qt::AlignTop|Qt::AlignHCenter);
ui->customPlot->legend->setBrush(QColor(255, 255, 255, 200));
QPen legendPen;
legendPen.setColor(QColor(130, 130, 130, 200));
ui->customPlot->legend->setBorderPen(legendPen);
QFont legendFont = font();
legendFont.setPointSize(10);
ui->customPlot->legend->setFont(legendFont);
ui->customPlot->setInteractions(QCP::iRangeDrag | QCP::iRangeZoom);

}
void MainWindow::makeTableView()
{
    QStandardItemModel *model = new QStandardItemModel(2,3,this); // 2 Rows and 3 Columns

    model->setHorizontalHeaderItem(0,new QStandardItem(QString("Nombre Employés")));
    model->setHorizontalHeaderItem(1,new QStandardItem(QString("Admin")));
    model->setHorizontalHeaderItem(2,new QStandardItem(QString("Agent de Services")));
    model->setHorizontalHeaderItem(3,new QStandardItem(QString("Agent d'entretien")));
     model->setHorizontalHeaderItem(4,new QStandardItem(QString("Agent de Sécurité")));




    model->setVerticalHeaderItem(0,new QStandardItem(QString("")));
    model->setVerticalHeaderItem(1,new QStandardItem(QString("Total")));

    for (int i=1;i<2;i++){
    int j=0;
    QStandardItem *Row = new QStandardItem(QString::number(Etmp.getNombreEmployes()));
    model->setItem(i,j,Row);
    j++;
    double pourcentage=Etmp.getNombreEmploye("Admin")*100/Etmp.getNombreEmployes();
    Row = new QStandardItem(QString::number(pourcentage)+'%');
    model->setItem(i,j,Row);
    j++;
    pourcentage=Etmp.getNombreEmploye("Agent de Service")*100/Etmp.getNombreEmployes();
    Row = new QStandardItem(QString::number(pourcentage)+'%');
    model->setItem(i,j,Row);

    j++;
    pourcentage=Etmp.getNombreEmploye("Agent d'entretien")*100/Etmp.getNombreEmployes();
    Row = new QStandardItem(QString::number(pourcentage)+'%');
    model->setItem(i,j,Row);

    j++;
    pourcentage=Etmp.getNombreEmploye("Agent de securite")*100/Etmp.getNombreEmployes();
    Row = new QStandardItem(QString::number(pourcentage)+'%');
    model->setItem(i,j,Row);


    }


    ui->tableView_stat->setModel(model);
    ui->tableView_stat->setVisible(false);
    ui->tableView_stat->resizeColumnsToContents();
    ui->tableView_stat->resizeRowsToContents();
    ui->tableView_stat->setVisible(true);
    ui->tableView_stat->horizontalHeader()->setStretchLastSection(true);
    ui->tableView_stat->verticalHeader()->setStretchLastSection(true);

}

void MainWindow::on_pushButton_AJOUTER_clicked()
{
  //QString password = "monmotdepasse";
  //QByteArray hashedPassword = QCryptographicHash::hash(password.toUtf8(), QCryptographicHash::Sha256);
  //Collect
   int cin = ui->lineEdit_ID->text().toInt();
   QString nom = ui->lineEdit_NOM->text();
   QString prenom = ui->lineEdit_PRENOM->text();
   QString mail = ui->lineEdit_MAIL->text();
   int age = ui->lineEdit_AGE->text().toInt();
   QString role = ui->comboBox->currentText();
   QString mdp = ui->lineEdit_MDP->text();
   QString mdpc = ui->lineEdit_MDP_C->text();



    // Vérification que tous les champs sont remplis
    if (cin == 0 || nom.isEmpty() || prenom.isEmpty() || mail.isEmpty() || age == 0 || mdp.isEmpty() || mdpc.isEmpty()) {
        /*QMessageBox::critical(nullptr, QObject::tr("Erreur"),
            QObject::tr("Tous les champs sont obligatoires.\n"
                        "Veuillez remplir tous les champs."), QMessageBox::Cancel);*/
        ui->lineEdit_MESSAGE->setText("Tous les champs sont obligatoires.\n"
                                      "Veuillez remplir tous les champs.");
        return;
    }
    QString input = ui->lineEdit_ID->text();
        QRegularExpression regex("^[0-9]{2,}$");
        QRegularExpressionMatch match = regex.match(input);
        if (!match.hasMatch()) {
            QMessageBox::warning(this, "Erreur de saisie", "L'ID doit être composé d'au moins deux chiffres.");
            ui->lineEdit_ID->clear();
        }


    // Vérification que le nom contient plus de 3 caractères et ne contient pas de chiffres
    if (nom.length() < 3 || nom.contains(QRegExp("[0-9]"))) {
       ui->lineEdit_MESSAGE->setText("Veuillez saisir un nom valide !");
        /*QMessageBox::critical(nullptr, QObject::tr("Erreur"),
            QObject::tr("Veuillez saisir un nom valide !"), QMessageBox::Cancel);*/
        return;
    }
    // Vérification de la validité du mail
     QRegularExpression Mailregex("^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");

    if (!Mailregex.match(mail).hasMatch()) {
        ui->lineEdit_MESSAGE->setText("Veuillez saisir une adresse mail valide !");
        /*QMessageBox::critical(nullptr, QObject::tr("Erreur"),
            QObject::tr("Veuillez saisir une adresse mail valide !"), QMessageBox::Cancel);*/
        return;
    }
    // Vérification que l'âge est supérieur ou égal à 18 ans
    if (age < 18) {
         ui->lineEdit_MESSAGE->setText("L'âge doit être supérieur ou égal à 18 ans.");
        /*QMessageBox::critical(nullptr, QObject::tr("Erreur"),
            QObject::tr("L'âge doit être supérieur ou égal à 18 ans."), QMessageBox::Cancel);*/
        return;
    }

    // Vérification que les deux mots de passe sont identiques
    if (mdp != mdpc) {
        ui->lineEdit_MESSAGE->setText("Les mots de passe ne sont pas identiques.");
        /*QMessageBox::critical(nullptr, QObject::tr("Erreur"),
            QObject::tr("Les mots de passe ne sont pas identiques."), QMessageBox::Cancel);*/
        return;
    }

    // Vérification que le mot de passe contient au moins 8 caractères, une lettre minuscule, une lettre majuscule, un chiffre et un caractère spécial
    QRegularExpression passwordRegex("^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$");
    if (!passwordRegex.match(mdp).hasMatch()) {
        //ui->lineEdit_MESSAGE->setText("Le mot de passe doit contenir au moins 8 caractères, \n" "une lettre minuscule, une lettre majuscule, \n"   " un chiffre et un caractère spécial.");
        //return;
          ui->lineEdit_MESSAGE->setText("");
        QMessageBox::critical(nullptr, QObject::tr("Erreur"),
          QObject::tr("Le mot de passe doit contenir au moins 8 caractères, une lettre minuscule, une lettre majuscule, un chiffre et un caractère spécial."), QMessageBox::Ok);
    return;
    }

    // Tous les contrôles de saisie sont passés, on peut ajouter l'employé
    QByteArray mdpHex = QByteArray::fromHex(mdp.toUtf8());

    Employe E(cin, nom, prenom, mail, age, role, mdp);
    bool test = E.ajouter();
    if (test) {
        ui->tableView->setModel(Etmp.afficher());
         ui->lineEdit_MESSAGE->setText("");
         on_pushButton_annuler_clicked();
        QMessageBox::information(nullptr, QObject::tr("Succès"),
            QObject::tr("L'employé a été ajouté avec succès."), QMessageBox::Ok);
    } else {
        QMessageBox::critical(nullptr, QObject::tr("Erreur"),
          QObject::tr("L'employé n'a pas été ajouté !"), QMessageBox::Ok);
    }
}


