MainWindow::MainWindow(QWidget *parent)
    : QMainWindow(parent)
    , ui(new Ui::MainWindow)
{
    ui->setupUi(this);
     this->setWindowTitle("");
    ui->tableView->setModel(Etmp.afficher());

   ui->lineEdit_ID->setValidator( new QIntValidator(0, 99999999, this));// INT
   ui->text_id->setValidator( new QIntValidator(0, 99999999, this));// INT ON EDIT

    ui->lineEdit_AGE->setValidator( new QIntValidator(0, 99999999, this));// INT
    ui->text_age->setValidator( new QIntValidator(0, 99999999, this));// INT ON EDIT


    QRegExp nomRegex("^[a-zA-ZéèêëîïôöùûüçÀÁÂÃÄÅÆÈÉÊËÎÏÔÖÙÛÜÇ]+$");//NOM
    QValidator *nomValidator = new QRegExpValidator(nomRegex, this);

    ui->lineEdit_NOM->setValidator(nomValidator);
    ui->text_nom->setValidator(nomValidator);

    ui->lineEdit_PRENOM->setValidator(nomValidator);
    ui->text_prenom->setValidator(nomValidator);




     ui->comboBox->addItem("");
     ui->comboBox->addItem("Agent de Service");
     ui->comboBox->addItem("Agent de securite");
     ui->comboBox->addItem("Agent d'entretien");
     ui->comboBox->addItem("Admin");

      //VISUALISER
      ui->comboBox_R->addItem("");
      ui->comboBox_R->addItem("Agent de Service");
      ui->comboBox_R->addItem("Agent de securite");
      ui->comboBox_R->addItem("Agent d'entretien");
      ui->comboBox_R->addItem("Admin");
    //autocomplete
      QCompleter *completer = new QCompleter(this);
      QStringListModel *completerModel = new QStringListModel(this);
      completer->setModel(completerModel);
      completerModel->setStringList(Etmp.getListeCles()); // Utiliser la méthode getListeCles
      ui->lineEdit_chercherE->setCompleter(completer);


      ui->pushButton_home->setStyleSheet("background-color:  rgb(8, 103, 94);color: #fff;border-top-left-radius: 20px;");


       update(); // Update the screen to see the changes
      int nombreEmployes = Etmp.getNombreEmployes();
      QString qstrNombreEmployes = QString::number(nombreEmployes);
      ui->label_nbE->setText(qstrNombreEmployes);
      //ui->pushButton_employe->setEnabled(0);


       MainWindow::makePlot();
       MainWindow::makePlot_second();
       MainWindow::makeTableView();
       MainWindow::chartPie();
       //OFFRE

         ui->le_code->setValidator( new QIntValidator(0, 99999999, this));///accepte seulement les entiers
         ui->le_prix->setValidator( new QIntValidator(0, 99999999, this));
         ui->le_cin->setValidator( new QIntValidator(0, 99999999, this));
         ui->tab_offre->setModel(o.afficher());
         //
         QString style = "QGroupBox {border: 1px solid #B2DFDB; border-top: 2px solid #26A69A; margin-top: 0.5em;}"
                         "QGroupBox::title {subcontrol-origin: margin; subcontrol-position: top center; padding: 0 3px;}";
         ui->groupBox->setStyleSheet(style);
         ui->groupBox_7->setStyleSheet(style);
         ui->groupBox_8->setStyleSheet(style);
         ui->groupBox_9->setStyleSheet(style);
         ui->groupBox_6->setStyleSheet(style);
         ui->groupBox_5->setStyleSheet(style);
         ui->groupBox_4->setStyleSheet(style);
         ui->groupBox_3->setStyleSheet(style);
         ui->groupBox_2->setStyleSheet(style);
         //
         QString tabWidgetStyle = "QTabWidget::pane {"
                                  "border-bottom: 1px solid #1abc9c;"
                                  "}"
                                  "QTabBar::tab:selected, QTabBar::tab:hover {"
                                  "background-color: rgb(1, 141, 127);"
                                  "border-bottom: 5px solid red;"
                                  "}"
                                  "QTabBar::tab:selected {"
                                  "color: white;"
                                  "}";

         // Appliquer le style au QTabWidget  tabWidget_2 tabWidget_station
         ui->tabWidget_service->setStyleSheet(tabWidgetStyle);
         ui->tabWidget_employe->setStyleSheet(tabWidgetStyle);
         ui->tabWidget_station->setStyleSheet(tabWidgetStyle);

           //ui->tabWidget_employe->setStyleSheet(tabWidgetStyle);
            //ui->tabWidget_employe->setStyleSheet(tabWidgetStyle);


         // STYLE


 }

