void MainWindow::on_pushButton_chercherE_clicked()
{
    QString clef = ui->lineEdit_chercherE->text().trimmed();

    if (clef.isEmpty()) {
        QMessageBox::warning(this, "Recherche invalide", "Veuillez entrer une clé de recherche valide.");
        return;
    }

    // Création d'un modèle de chaînes de caractères pour le completer
    QStringListModel* completerModel = new QStringListModel(this);

    // Remplissage du modèle avec les données de la base de données
    completerModel->setStringList(Etmp.getListeCles());

    // Création et configuration du completer
    QCompleter* completer = new QCompleter(completerModel, this);
    completer->setCaseSensitivity(Qt::CaseInsensitive);
    completer->setCompletionMode(QCompleter::PopupCompletion);
    completer->setWrapAround(false);

    // Attribution du completer au champ de recherche
    ui->lineEdit_chercherE->setCompleter(completer);

    QSqlQueryModel* model = Etmp.rechercher(clef);

    if (!model->rowCount()) {
        QMessageBox::information(this, "Résultat de la recherche", "Aucun résultat trouvé pour la clé de recherche spécifiée.");
        return;
    }

    ui->tableView->setModel(model);
}
